{
  "name": "@adibenmatdev/agenv",
  "version": "1.1.3",
  "description": "The agent development environment — build, run, and monitor AI agents from a full web IDE with split terminals, file editing, and session management",
  "main": "electron.js",
  "bin": {
    "agenv": "cli.js"
  },
  "scripts": {
    "preinstall": "node -e \"try{const p=JSON.parse(require('fs').readFileSync(require('path').join(require('os').homedir(),'.agenv.pid'),'utf8'));process.kill(p.pid,'SIGTERM')}catch{}\"",
    "start": "node server.js",
    "stop": "node scripts/manage.js stop",
    "restart": "node scripts/manage.js stop && node server.js",
    "destroy": "node scripts/manage.js destroy",
    "status": "node scripts/manage.js status",
    "test": "node --test test/api.test.js",
    "watch": "nodemon --watch server.js --watch public/ --ext js,html,css --delay 500ms -- server.js",
    "electron": "electron .",
    "electron:dev": "nodemon --watch electron.js --watch server.js --watch public/ --ext js,html,css --delay 500ms --exec \"electron .\"",
    "rebuild": "electron-rebuild -f -w @lydell/node-pty",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "dev.agenv.app",
    "productName": "Agenv",
    "directories": {
      "output": "dist"
    },
    "files": [
      "server.js",
      "electron.js",
      "preload.js",
      "cli.js",
      "public/**/*",
      "scripts/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "win": {
      "target": ["nsis", "portable"],
      "icon": "assets/icon.svg"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.svg",
      "uninstallerIcon": "assets/icon.svg",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "mac": {
      "target": ["dmg"],
      "icon": "assets/icon.svg",
      "category": "public.app-category.developer-tools"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "icon": "assets/icon.svg",
      "category": "Development"
    }
  },
  "keywords": [
    "agent",
    "ai",
    "ide",
    "terminal",
    "pty",
    "websocket",
    "remote",
    "shell",
    "tty",
    "xterm",
    "cli",
    "claude",
    "devtools"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adibenmati/agenv.git"
  },
  "homepage": "https://github.com/adibenmati/agenv",
  "bugs": {
    "url": "https://github.com/adibenmati/agenv/issues"
  },
  "author": "Adi Ben Matitiau",
  "engines": {
    "node": ">=16.0.0"
  },
  "files": [
    "cli.js",
    "server.js",
    "electron.js",
    "preload.js",
    "public/",
    "scripts/",
    "assets/",
    "LICENSE",
    "README.md"
  ],
  "license": "Apache-2.0",
  "dependencies": {
    "@lydell/node-pty": "^1.0.1",
    "express": "^4.21.2",
    "qrcode-terminal": "^0.12.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.2",
    "electron": "^41.2.1",
    "electron-builder": "^26.0.12"
  }
}
